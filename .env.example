# Local development: enable the dev-login bypass so you don't need an Auth0
# tenant. Set to false to authenticate against real Auth0.
AUTH_DEV_MODE=true

# Auth0 application settings (required when AUTH_DEV_MODE=false).
# Create a "Regular Web Application" in the Auth0 dashboard.
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Must be registered as an Allowed Callback URL in Auth0.
AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
# Must be registered as an Allowed Logout URL in Auth0.
AUTH0_LOGOUT_RETURN_URL=http://localhost:3000/

# SQLite database file (optional, defaults to fiber.db).
# DB=fiber.db
